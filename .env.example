APP_NAME="notifications-api"
NODE_ENV="development"
PORT="3003"
API_PREFIX="api"
TRUST_PROXY="false"
TRUST_PROXY_HOPS="1"
TRUST_PROXY_CIDRS=""
APP_TIME_ZONE="America/Bogota"

CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174"
CORS_CREDENTIALS="true"
CORS_METHODS="GET,HEAD,POST,PUT,PATCH,DELETE,OPTIONS"
CORS_ALLOWED_HEADERS="Authorization,Content-Type,X-Request-Id"
CORS_EXPOSED_HEADERS="X-Request-Id,X-Response-Time"

LOG_LEVEL="debug"
LOG_PRETTY_PRINT="true"

DATABASE_URL="postgresql://postgres:password@localhost:5432/truo_db?schema=notifications"
REDIS_URL="redis://localhost:6379"
QUEUE_PREFIX="notifications-api"
AUTH_ACCESS_TOKEN_SECRET="shared-access-secret-change-me"
NOTIFICATIONS_INTERNAL_TOKEN="change-me-notifications-internal-token"
EXPO_ACCESS_TOKEN=""
EXPO_PUSH_API_URL="https://exp.host/--/api/v2/push/send"
EXPO_PUSH_TIMEOUT_MS="12000"

RATE_LIMIT_TTL="60000"
RATE_LIMIT_LIMIT="100"
SENSITIVE_RATE_LIMIT_TTL="60000"
SENSITIVE_RATE_LIMIT_LIMIT="120"
